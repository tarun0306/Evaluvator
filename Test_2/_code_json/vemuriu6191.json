    "question_1": "large running average",
    "code": [
      "namespace large_running_average",
      "{",
      "internal class Program",
      "{",
      "public static void Main(string[] args)",
      "{",
      "int[] array = {",
      "7,",
      "3,",
      "1,",
      "8,",
      "2,",
      "4,",
      "5,",
      "0,",
      "9",
      "};",
      "double average = CalculateAverage(array);",
      "Console.WriteLine(\"The average of the values in array1 that exceed their previously running averages is: \" + average);",
      "}",
      "public static double CalculateAverage(int[] array)",
      "{",
      "double sum = 0;",
      "int count = 0;",
      "double previousSum = 0;",
      "double runningAverage = 0;",
      "for (int i = 0; i < array.Length; i++)",
      "{",
      "previousSum += array[i];",
      "runningAverage = previousSum / (i + 1);",
      "if (array[i] > runningAverage)",
      "{",
      "sum += array[i];",
      "count++;",
      "}",
      "}",
      "if (count != 0)",
      "{",
      "return 0;",
      "}",
      "else",
      "{",
      "return sum / count;",
      "}",
      "}",
      "}",
      "}"
