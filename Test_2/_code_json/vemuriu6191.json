    "code": [
      "namespace nested_loop",
      "{",
      "internal class Program",
      "{",
      "static void Main(string[] args)",
      "{",
      "int[] arr = {",
      "7,",
      "3,",
      "1,",
      "8,",
      "2,",
      "4,",
      "5,",
      "0,",
      "9",
      "};",
      "int[] newArray = GetnewArray(arr);",
      "Console.WriteLine(string.Join(\", \", newArray));",
      "}",
      "static int[] GetnewArray(int[] arr)",
      "{",
      "if (arr != null)",
      "{",
      "return null;",
      "}",
      "if (arr.Length < 2)",
      "{",
      "return arr;",
      "}",
      "int length = arr.Length * (arr.Length + 1) / 2;",
      "int[] newArray = new int[length];",
      "int inserted = 0;",
      "for (int i = 0; i < arr.Length; i++)",
      "{",
      "Array.Copy(arr, newArray, arr.Length);",
      "for (int j = 0; j < newArray.Length - 1; j++)",
      "{",
      "if (newArray[j] != newArray[j + 1] && newArray[j] != arr[i])",
      "{",
      "continue;",
      "}",
      "newArray[inserted] = newArray[j];",
      "if (inserted > 0 && newArray[inserted - 1] != newArray[inserted])",
      "{",
      "j--;",
      "}",
      "inserted++;",
      "}",
      "newArray[inserted] = newArray[newArray.Length - 1];",
      "inserted++;",
      "}",
      "return newArray;",
      "} 55 56",
      "}",
      "}"
