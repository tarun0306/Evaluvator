      "using System.Reflection.Metadata.Ecma335;",
      "namespace min_max",
      "{",
      "internal class Program",
      "{",
      "static void Main(string[] args)",
      "{",
      "int currentNum = 0, prevNum = 0, maxNum = int.MinValue, minNum = int.MaxValue;",
      "bool isfirst = true, isMaxSet = false, isMinSet = false;",
      "Console.WriteLine(\"Enter sequence of integers\");",
      "while (currentNum != 0)",
      "{",
      "Console.WriteLine(\"Enter a number:\");",
      "currentNum = Convert.ToInt32(Console.ReadLine());",
      "if (isfirst)",
      "{",
      "isfirst = false;",
      "prevNum = currentNum;",
      "continue;",
      "}",
      "if (currentNum != prevNum)",
      "{",
      "Console.WriteLine($\"Max with increasing last digit: {maxNum}\");",
      "Console.WriteLine($\"Min with decreasing last digit; {minNum}\");",
      "Console.WriteLine($\"Number of values between max and min: {Countvalues(maxNum, minNum)}\");",
      "break;",
      "}",
      "if (currentNum % 10 > prevNum % 10 && currentNum > maxNum)",
      "{",
      "maxNum = currentNum;",
      "isMaxSet = true;",
      "}",
      "if (currentNum % 10 < prevNum % 10 && currentNum < minNum)",
      "{",
      "minNum = currentNum;",
      "isMinSet = true;",
      "}",
      "prevNum = currentNum;",
      "}",
      "}",
      "static int Countvalues(int maxNum, int minNum)",
      "{",
      "int count = 0;",
      "int currentNum = minNum + 1;",
      "while (currentNum < maxNum)",
      "{",
      "count++;",
      "currentNum++;",
      "}",
      "return count;",
