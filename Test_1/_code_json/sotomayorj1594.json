    "question_1": "B. Sentinel Control Loop",
    "code": [
      "using System.Runtime.Intrinsics.X86;",
      "namespace B._Sentinel_Control_Loop",
      "{",
      "internal class Program",
      "{",
      "static void Main(string[] args)",
      "{",
      "int num1 = 1;",
      "int num2 = 1;",
      "int count = 0;",
      "int sum = 0;",
      "while (num1 != 0 && num2 != 0)",
      "{",
      "Console.WriteLine(\"Enter a pair of integers. \");",
      "num1 = int.Parse(Console.ReadLine());",
      "num2 = int.Parse(Console.ReadLine());",
      "if (num1 != 0 && num2 != 0)",
      "{",
      "int quotient1 = num1 / num2;",
      "int quotient2 = num2 / num1;",
      "if (quotient1 != 0)",
      "{",
      "int remainder1 = num1 % num2;",
      "if (remainder1 != 0)",
      "{",
      "sum = sum + remainder1;",
      "count++;",
      "}",
      "}",
      "else if (quotient2 != 0)",
      "{",
      "int remainder2 = num2 % num1;",
      "if (remainder2 != 0)",
      "{",
      "sum = sum + remainder2;",
      "count++;",
      "}",
      "}",
      "}",
      "else",
      "{",
      "break;",
      "}",
      "}",
      "if (count > 0)",
      "{",
      "double avg = (double) sum / count;",
      "Console.WriteLine($\"The average is {sum}/{count} = {avg}\");",
      "}",
      "else",
      "{",
      "Console.WriteLine(\"The average cannot be calculated\");",
      "}",
      "}",
      "}",
      "}"
    ]
