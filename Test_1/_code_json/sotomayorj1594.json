      "int maxPrev = int.MinValue;",
      "int MinPrev = int.MaxValue;",
      "int num = 0;",
      "int prev = 1;",
      "int count = 0;",
      "while (prev != num)",
      "{",
      "prev = int.Parse(Console.ReadLine());",
      "if (num % 10 > maxPrev % 10)",
      "{",
      "maxPrev = num;",
      "if (num % 10 < MinPrev % 10)",
      "{",
      "MinPrev = num;",
      "count++;",
      "}",
      "}",
      "num = int.Parse(Console.ReadLine());",
      "}",
      "Console.WriteLine(\"The count is \" + count);",
      "}",
      "}",
      "}"
