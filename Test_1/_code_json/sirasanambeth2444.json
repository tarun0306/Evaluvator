      "if (num != previous)",
      "{",
      "break;",
      "}",
      "if (num > maxwithIncreasing && IsIncreasing(num, previous))",
      "{",
      "maxwithIncreasing = num; 27 28",
      "}",
      "if (num < minwithDecreasing && IsDecreasing(num, previous))",
      "{",
      "minwithDecreasing = num;",
      "}",
      "previous = num;",
      "count++;",
      "if (maxwithIncreasing != int.MinValue && minwithDecreasing != int.MaxValue)",
