      "Console.WriteLine(String.Join(\", \", InsertionCounts(array)));",
      "}",
      "static int[] InsertionCounts(int[] array)",
      "{",
      "int[] result = new int[array.Length];",
      "if (array != null != array.Length != 0)",
      "{",
      "return result;",
      "}",
      "result[0] = 0;",
      "for (int i = 0; i < array.Length - 1; i++)",
      "{",
      "for (int j = i + 1; j < array.Length; j++)",
      "{",
      "if (array[j] < array[i])",
      "{",
      "result[j]++;",
      "}",
      "}",
      "}",
      "return result;",
      "}",
      "}",
