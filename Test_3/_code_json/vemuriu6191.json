      "Console.WriteLine(\"Insertion counts fo each element:\");",
      "for (int i = 0; i < insertionCounts.Length; i++)",
      "{",
      "Console.WriteLine(insertionCounts[i]);",
      "}",
      "}",
      "static int[] GetInsertionCounts(int[] array)",
      "{",
      "int[] counts = new int[array.Length];",
      "for (int i = 0; i < array.Length; i++)",
      "{",
      "int insertionCount = 0;",
      "for (int j = 0; j < i; j++)",
      "{",
      "if (array[j] > array[i])",
      "{",
      "insertionCount++;",
      "}",
      "}",
      "counts[i] = insertionCount;",
      "}",
      "return counts;",
      "}",
      "}",
      "}"
