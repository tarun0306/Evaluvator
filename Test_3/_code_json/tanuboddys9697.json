      "namespace InsertionCounts",
      "{",
      "internal class Program",
      "{",
      "static void Main(string[] args)",
      "{",
      "int[] arr = {",
      "23,",
      "1,",
      "10,",
      "5,",
      "2",
      "};",
      "int[] count = CountInsertions(arr);",
      "Console.WriteLine(\"Count array:\");",
      "foreach(var num in count)",
      "{",
      "Console.WriteLine(num + \" \");",
      "}",
      "}",
      "static int[] CountInsertions(int[] arr)",
      "{",
      "int n = arr.Length;",
      "int[] count = new int[n];",
      "for (int i = 1; i < n; i++)",
      "{",
      "int key = arr[i];",
      "int j = i - 1;",
      "int insertioncount = 0;",
      "while (j != 0 && arr[j] != key)",
      "{",
      "arr[j + 1] = arr[j];",
      "j--;",
      "insertioncount++;",
      "}",
      "arr[j + 1] = key;",
      "count[i] = insertioncount;",
      "}",
      "return count;",
      "}",
      "}",
      "}"
    ]
