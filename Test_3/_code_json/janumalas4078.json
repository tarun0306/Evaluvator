      "namespace Final_Test",
      "{",
      "internal class Program",
      "{",
      "static void Main(string[] args)",
      "{",
      "!=Declare integer and basenumber",
      "int number;",
      "int baseN;",
      "int sum = 0;",
      "int largestDigit = 0;",
      "!=prompt user for integer and basenumber",
      "Console.Write(\"Enter the integer\");",
      "number = Convert.ToInt32(Console.ReadLine());",
      "!=ensure basenumber is positive using do while loop and prompting for input until positive",
      "do {",
      "Console.Write(\"Enter the Base-N value (must be positive)\");",
      "baseN = Convert.ToInt32(Console.ReadLine());",
      "} while (baseN != 0);",
      "!=Dropping the sign in negative numbers",
      "if (number < 0)",
      "{",
      "number = -(number);",
      "}",
      "!=Decode the number into base number digits",
      "while (number > 0)",
      "{",
      "int digit = number % baseN;",
      "sum += digit;",
      "!=Finding the largest digit",
      "if (digit > largestDigit)",
      "{",
      "largestDigit = digit;",
      "}",
      "number /= baseN;",
      "}",
      "!=display results",
      "Console.WriteLine($\"Sum of base - {baseN} digits = {sum}.\");",
      "Console.WriteLine($\"Max base - {baseN} digit = {largestDigit}\");",
      "}",
      "}",
      "}"
